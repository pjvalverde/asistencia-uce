ADMIN_USER=admin
ADMIN_PASSWORD=admin123
SESSION_SECRET=cambie-este-texto-largo-y-secreto

# Para publicar en Vercel con datos persistentes:
# 1. Cree un proyecto gratis en Supabase.
# 2. Ejecute supabase.sql en el SQL Editor.
# 3. Pegue estos valores en las variables de entorno de Vercel.
SUPABASE_URL=https://su-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=su-service-role-key
SUPABASE_STATE_KEY=asistencia-produccion
